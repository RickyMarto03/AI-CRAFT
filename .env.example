# Copia questo file in .env e riempi i valori reali. .env non va mai committato.

# --- Database ---
# Default: sqlite file in data/aicraft.db, non serve toccarlo.
# AICRAFT_DATABASE_URL=sqlite:///data/aicraft.db

# --- Google Sheet (Reference Sync, lettura + mark scaricati) ---
# Path al JSON della service account Google con permesso di lettura/edit sullo sheet.
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json
# ID dello sheet (dalla URL: https://docs.google.com/spreadsheets/d/<QUESTO_ID>/edit)
GOOGLE_SHEET_ID=
# Nomi dei tab da leggere, separati da virgola.
GOOGLE_SHEET_TABS=CAROSELLI,VIRAL GENERAL

# Se 1, dopo un download riuscito marca lo Sheet: video -> DONE RICKY,
# caroselli -> background colorato sulla cella del link.
GOOGLE_SHEET_MARK_DOWNLOADS=1
GOOGLE_SHEET_CAROUSEL_MARK_COLOR=1.0,0.95,0.65

# --- Instagram (download reference via instagrapi) ---
# Nessuna password qui: la sessione viene importata dai cookie di un browser
# locale gia' loggato su instagram.com (via browser_cookie3). Assicurati di
# essere loggato in quel browser prima di lanciare il sync la prima volta.
# Valori tipici: chrome, safari, firefox, edge, brave.
INSTAGRAM_BROWSER=chrome

# --- Whisper (trascrizione locale) ---
# tiny | base | small | medium | large-v3 — trade-off velocita'/qualita'
AICRAFT_WHISPER_MODEL=small

# --- Libreria reference locale ---
# Quante settimane recenti usare per pescare contenuti dal DB locale.
AICRAFT_REFERENCE_SELECTION_WEEKS=2
# Dopo quanti giorni eliminare dal DB/file locali i reference originali IG.
# Gli asset generati da AI-CRAFT non vengono toccati.
AICRAFT_REFERENCE_RETENTION_DAYS=45
# Quanti reference scaricare per run di sync. 0 = nessun limite.
AICRAFT_REFERENCE_SYNC_MAX_ITEMS=25
# Policy del sync automatico per categoria:
# TAB:CATEGORIA=numero_da_scaricare_per_run, separati da virgola.
AICRAFT_REFERENCE_SYNC_POLICY=CAROSELLI:BOOBS=5,CAROSELLI:BOOTY=5,CAROSELLI:GENERAL=5,VIRAL GENERAL:TALKING=5,VIRAL GENERAL:BALLETTI/LIPSYNC=5,VIRAL GENERAL:CAPTION=5
