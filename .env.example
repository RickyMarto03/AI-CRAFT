# Copia questo file in .env e riempi i valori reali. .env non va mai committato.

# --- Database ---
# Default: sqlite file in data/aicraft.db, non serve toccarlo.
# AICRAFT_DATABASE_URL=sqlite:///data/aicraft.db

# --- Google Sheet (Reference Sync, accesso READ-ONLY) ---
# Path al JSON della service account Google con permesso di lettura sullo sheet.
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json
# ID dello sheet (dalla URL: https://docs.google.com/spreadsheets/d/<QUESTO_ID>/edit)
GOOGLE_SHEET_ID=
# Nomi dei tab da leggere, separati da virgola.
GOOGLE_SHEET_TABS=CAROSELLI,VIRAL GENERAL

# --- Instagram (download reference via Instaloader) ---
# Nessuna password qui: la sessione viene importata dai cookie di un browser
# locale gia' loggato su instagram.com (via browser_cookie3). Assicurati di
# essere loggato in quel browser prima di lanciare il sync la prima volta.
# Valori tipici: chrome, safari, firefox, edge, brave.
INSTAGRAM_BROWSER=chrome

# --- Whisper (trascrizione locale) ---
# tiny | base | small | medium | large-v3 — trade-off velocita'/qualita'
AICRAFT_WHISPER_MODEL=small
